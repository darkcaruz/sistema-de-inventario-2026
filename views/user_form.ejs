<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title><%= mode === 'edit' ? 'Editar usuario' : 'Nuevo usuario' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-dark bg-dark mb-4">
  <div class="container-fluid">
    <a class="navbar-brand" href="/devices">Inventario</a>
    <div class="d-flex gap-2">
      <span class="navbar-text text-light">
        <%= currentUser %> (<%= currentRole %>)
      </span>
      <a href="/logout" class="btn btn-outline-light btn-sm">Salir</a>
    </div>
  </div>
</nav>

<div class="container">
  <h3 class="mb-3">
    <%= mode === 'edit' ? 'Editar usuario' : 'Crear nuevo usuario' %>
  </h3>

  <% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <form method="POST" action="<%= mode === 'edit' ? '/users/' + user.id + '/edit' : '/users/new' %>">
    <div class="mb-3">
      <label class="form-label">Usuario</label>
      <input
        type="text"
        name="username"
        class="form-control"
        required
        value="<%= user ? user.username : '' %>">
    </div>

    <div class="mb-3">
      <label class="form-label">
        Contraseña
        <% if (mode === 'edit') { %>
          <small class="text-muted">(déjala en blanco para no cambiarla)</small>
        <% } %>
      </label>
      <input
        type="password"
        name="password"
        class="form-control"
        <%= mode === 'new' ? 'required' : '' %>>
    </div>

    <div class="mb-3">
      <label class="form-label">Rol</label>
      <select name="role" class="form-select" required>
        <option value="">Seleccione un rol</option>
        <option value="admin" <%= user && user.role === 'admin' ? 'selected' : '' %>>admin (todo acceso)</option>
        <option value="editor" <%= user && user.role === 'editor' ? 'selected' : '' %>>editor (crear/editar)</option>
        <option value="viewer" <%= user && user.role === 'viewer' ? 'selected' : '' %>>viewer (solo lectura)</option>
      </select>
    </div>

    <button class="btn btn-primary" type="submit">
      <%= mode === 'edit' ? 'Guardar cambios' : 'Crear usuario' %>
    </button>
    <a href="/users" class="btn btn-secondary">Volver</a>
  </form>
</div>
</body>
</html>

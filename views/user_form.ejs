<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= mode==='edit' ? 'Editar' : 'Nuevo' %> Usuario | INFORMATICA
  </title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>

  <nav class="navbar navbar-expand-lg sticky-top">
    <div class="container-fluid">
      <a class="navbar-brand" href="/devices">
        <i class="bi bi-cpu-fill me-2"></i>INFORMATICA
      </a>
      <a href="/logout" class="btn btn-outline-light btn-sm">Salir</a>
    </div>
  </nav>

  <div class="container mt-5 animate-fade-in">
    <div class="mb-4">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
          <li class="breadcrumb-item"><a href="/users" class="text-info text-decoration-none">Usuarios</a></li>
          <li class="breadcrumb-item active text-secondary" aria-current="page">
            <%= mode==='edit' ? 'Editar' : 'Nuevo' %>
          </li>
        </ol>
      </nav>
      <h3><i class="bi bi-person-gear me-2 text-info"></i>
        <%= mode==='edit' ? 'Modificar Usuario' : 'Crear Acceso' %>
      </h3>
    </div>

    <div class="card" style="max-width: 600px;">
      <div class="card-header"><i class="bi bi-shield-lock me-2"></i> Credenciales y Privilegios</div>
      <div class="card-body p-4">

        <% if (error) { %>
          <div class="alert alert-danger py-2 small bg-danger bg-opacity-10 border-0 text-danger mb-4">
            <i class="bi bi-exclamation-circle me-2"></i>
            <%= error %>
          </div>
          <% } %>

            <form method="POST" action="<%= mode === 'edit' ? '/users/' + user.id + '/edit' : '/users/new' %>">

              <div class="mb-4">
                <label class="form-label">Nombre de Usuario</label>
                <div class="input-group">
                  <span class="input-group-text bg-dark border-secondary text-info"><i class="bi bi-person"></i></span>
                  <input type="text" name="username" class="form-control" required
                    value="<%= user ? user.username : '' %>" placeholder="ej: jdoe">
                </div>
              </div>

              <div class="mb-4">
                <label class="form-label">Contraseña</label>
                <div class="input-group">
                  <span class="input-group-text bg-dark border-secondary text-info"><i class="bi bi-key"></i></span>
                  <input type="password" name="password" class="form-control" <%=mode==='new' ? 'required' : '' %>
                  placeholder="<%= mode==='edit' ? '(Dejar vacío para mantener actual)' : '••••••••' %>">
                </div>
              </div>

              <div class="mb-5">
                <label class="form-label">Rol del Sistema</label>
                <select name="role" class="form-select" required>
                  <option value="admin" <%=user && user.role==='admin' ? 'selected' : '' %>>Administrador (Acceso Total)
                  </option>
                  <option value="editor" <%=user && user.role==='editor' ? 'selected' : '' %>>Editor (Modificar
                    Inventario)</option>
                  <option value="viewer" <%=user && user.role==='viewer' ? 'selected' : '' %>>Visor (Solo Lectura)
                  </option>
                </select>
              </div>

              <div class="d-flex justify-content-end gap-3 mt-4 border-top pt-4">
                <a href="/users" class="btn btn-outline-light">Cancelar</a>
                <button class="btn btn-primary px-4" type="submit">
                  <i class="bi bi-check2-circle me-2"></i>
                  <%= mode==='edit' ? 'Actualizar Usuario' : 'Crear Cuenta' %>
                </button>
              </div>

            </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
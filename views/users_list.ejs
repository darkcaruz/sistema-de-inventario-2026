<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Usuarios | INFORMATICA</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>

  <nav class="navbar navbar-expand-lg sticky-top">
    <div class="container-fluid">
      <a class="navbar-brand" href="/devices">
        <i class="bi bi-cpu-fill me-2"></i>INFORMATICA
      </a>
      <a href="/logout" class="btn btn-outline-secondary btn-sm">Salir</a>
    </div>
  </nav>

  <div class="container mt-5 animate-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-5">
      <div>
        <h2>Gestión de Usuarios</h2>
        <p class="text-secondary small">Control de acceso y privilegios del sistema</p>
      </div>
      <a href="/users/new" class="btn btn-primary btn-sm"><i class="bi bi-person-plus-fill me-1"></i> Nuevo Usuario</a>
    </div>

    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead>
          <tr>
            <th>ID</th>
            <th>Usuario</th>
            <th>Rol / Nivel de Acceso</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(u=> { %>
            <tr>
              <td><span class="text-primary fw-medium">#<%= u.id %></span></td>
              <td><strong>
                  <%= u.username %>
                </strong></td>
              <td>
                <span
                  class="badge <%= u.role === 'admin' ? 'bg-danger' : (u.role === 'editor' ? 'bg-warning' : 'bg-success') %>">
                  <%= u.role.toUpperCase() %>
                </span>
              </td>
              <td class="text-end">
                <a href="/users/<%= u.id %>/edit" class="btn btn-sm btn-outline-primary">
                  <i class="bi bi-pencil"></i>
                </a>
              </td>
            </tr>
            <% }) %>
        </tbody>
      </table>
    </div>

    <div class="mt-4">
      <a href="/devices" class="btn btn-outline-secondary btn-sm">Volver al Inventario</a>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
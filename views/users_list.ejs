<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Usuarios del Sistema</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-dark bg-dark mb-4">
  <div class="container-fluid">
    <a class="navbar-brand" href="/devices">Inventario</a>
    <div class="d-flex gap-2">
      <span class="navbar-text text-light">
        <%= currentUser %> (<%= currentRole %>)
      </span>
      <a href="/logout" class="btn btn-outline-light btn-sm">Salir</a>
    </div>
  </div>
</nav>

<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Usuarios</h3>
    <a href="/users/new" class="btn btn-primary btn-sm">+ Nuevo usuario</a>
  </div>

  <table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>ID</th>
        <th>Usuario</th>
        <th>Rol</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% if (users.length === 0) { %>
        <tr>
          <td colspan="4" class="text-center">No hay usuarios</td>
        </tr>
      <% } %>

      <% users.forEach(u => { %>
        <tr>
          <td><%= u.id %></td>
          <td><%= u.username %></td>
          <td><%= u.role %></td>
          <td>
            <!-- Botón editar para todos los usuarios -->
            <a href="/users/<%= u.id %>/edit" class="btn btn-sm btn-warning">Editar</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <a href="/devices" class="btn btn-secondary btn-sm mt-3">Volver al inventario</a>
</div>
</body>
</html>

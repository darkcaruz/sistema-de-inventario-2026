<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Detalle Equipo</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
<nav class="navbar navbar-dark bg-dark mb-4">
  <div class="container-fluid">
    <a class="navbar-brand" href="/devices">Inventario</a>
    <div class="d-flex gap-2">
      <% if (currentRole === 'admin') { %>
        <a href="/users" class="btn btn-outline-light btn-sm">Usuarios</a>
      <% } %>
      <span class="navbar-text text-light">
        <%= currentUser %> (<%= currentRole %>)
      </span>
      <a href="/logout" class="btn btn-outline-light btn-sm">Salir</a>
    </div>
  </div>
</nav>

<div class="container">

  <div class="d-flex justify-content-between mb-3">
    <h3>Equipo: <%= device.name %></h3>
    <div class="d-flex gap-2">
      <% if (currentRole === 'admin' || currentRole === 'editor') { %>
        <a href="/devices/<%= device.id %>/edit" class="btn btn-warning btn-sm">Editar</a>
      <% } %>

      <% if (currentRole === 'admin') { %>
        <form method="POST" action="/devices/<%= device.id %>/delete"
              onsubmit="return confirm('¿Eliminar equipo y todo su historial?');">
          <button class="btn btn-danger btn-sm" type="submit">Eliminar</button>
        </form>
      <% } %>

      <a href="/devices" class="btn btn-secondary btn-sm">Volver</a>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header">Información del Equipo</div>
    <div class="card-body">
      <p><strong>Código:</strong> <%= device.code || '-' %></p>
      <p><strong>Marca / Modelo:</strong> <%= device.brand_model || '-' %></p>
      <p><strong>CPU:</strong> <%= device.cpu || '-' %></p>
      <p><strong>RAM:</strong> <%= device.ram || '-' %></p>
      <p><strong>Disco:</strong> <%= device.storage || '-' %></p>
      <p><strong>N° Serie:</strong> <%= device.serial_number || '-' %></p>
      <p><strong>Ubicación:</strong> <%= device.location || '-' %></p>
      <p><strong>Responsable:</strong> <%= device.responsible || '-' %></p>
      <p><strong>Estado:</strong> <%= device.status %></p>
      <p><strong>Observaciones:</strong><br><%= device.observations || '-' %></p>
    </div>
  </div>

  <h4>Historial de Asignaciones</h4>

  <% if (currentRole === 'admin' || currentRole === 'editor') { %>
  <div class="card mb-4">
    <div class="card-body">
      <form method="POST" action="/devices/<%= device.id %>/assign">
        <div class="row">
          <div class="col-md-4">
            <label>Asignado a</label>
            <input class="form-control" name="assigned_to" required>
          </div>
          <div class="col-md-3">
            <label>Cargo</label>
            <input class="form-control" name="role">
          </div>
          <div class="col-md-3">
            <label>Área</label>
            <input class="form-control" name="area">
          </div>
          <div class="col-md-2">
            <label>Fecha entrega</label>
            <input type="date" class="form-control" name="assigned_date" required>
          </div>
        </div>

        <div class="row mt-2 mb-3">
          <div class="col-md-12">
            <label>Notas</label>
            <input class="form-control" name="notes">
          </div>
        </div>

        <button class="btn btn-primary btn-sm">Agregar asignación</button>
      </form>
    </div>
  </div>
  <% } %>

  <table class="table table-striped">
    <thead>
      <tr>
        <th>ID</th>
        <th>Persona</th>
        <th>Cargo</th>
        <th>Área</th>
        <th>Entrega</th>
        <th>Devolución</th>
        <th>Notas</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% if (assignments.length === 0) { %>
      <tr><td colspan="8" class="text-center">Sin asignaciones</td></tr>
      <% } %>

      <% assignments.forEach(a => { %>
      <tr>
        <td><%= a.id %></td>
        <td><%= a.assigned_to %></td>
        <td><%= a.role || '-' %></td>
        <td><%= a.area || '-' %></td>
        <td><%= a.assigned_date || '-' %></td>
        <td><%= a.returned_date || '-' %></td>
        <td><%= a.notes || '-' %></td>
        <td>
          <% if (!a.returned_date && (currentRole === 'admin' || currentRole === 'editor')) { %>
            <form method="POST" action="/assignments/<%= a.id %>/close">
              <input type="date" name="returned_date" required>
              <button class="btn btn-success btn-sm mt-1">Cerrar</button>
            </form>
          <% } else if (a.returned_date) { %>
            ✔
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>

</div>
</body>
</html>

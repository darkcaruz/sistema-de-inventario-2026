<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Detalle | <%= device.name %>
  </title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>
  <nav class="navbar navbar-expand-lg sticky-top">
    <div class="container-fluid">
      <a class="navbar-brand" href="/devices">
        <i class="bi bi-cpu-fill me-2"></i>INFORMATICA
      </a>
      <div class="d-flex align-items-center gap-3">
        <span class="badge text-bg-dark d-none d-md-inline-block">
          <i class="bi bi-person-circle"></i>
          <%= currentUser %>
        </span>
        <a href="/logout" class="btn btn-outline-secondary btn-sm">Salir</a>
      </div>
    </div>
  </nav>

  <div class="container mt-5 animate-fade-in">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
      <div>
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item"><a href="/devices" class="text-primary text-decoration-none">Equipos</a></li>
            <li class="breadcrumb-item active text-secondary" aria-current="page">Detalle</li>
          </ol>
        </nav>
        <h3><i class="bi bi-box-seam me-2 text-primary"></i>
          <%= device.name %>
        </h3>
      </div>

      <div class="d-flex gap-2 mt-3 mt-md-0">
        <% if (currentRole==='admin' || currentRole==='editor' ) { %>
          <a href="/devices/<%= device.id %>/edit" class="btn btn-primary btn-sm">
            <i class="bi bi-pencil-square me-1"></i> Editar
          </a>
          <% } %>

            <% if (currentRole==='admin' ) { %>
              <form method="POST" action="/devices/<%= device.id %>/delete"
                onsubmit="return confirm('¿Eliminar equipo y todo su historial?');">
                <button class="btn btn-outline-danger btn-sm" type="submit">
                  <i class="bi bi-trash me-1"></i> Eliminar
                </button>
              </form>
              <% } %>
                <a href="/devices" class="btn btn-outline-secondary btn-sm">Volver</a>
      </div>
    </div>

    <div class="row">
      <div class="col-lg-5">
        <div class="card">
          <div class="card-header"><i class="bi bi-info-circle me-2"></i> Especificaciones</div>
          <div class="card-body">
            <div class="mb-3">
              <label class="text-secondary small d-block">Código Interno</label>
              <span class="fs-5 text-primary fw-medium">
                <%= device.code || 'N/A' %>
              </span>
            </div>
            <div class="row g-3">
              <div class="col-6">
                <label class="text-secondary small d-block">Marca / Modelo</label>
                <span>
                  <%= device.brand_model || '-' %>
                </span>
              </div>
              <div class="col-6">
                <label class="text-secondary small d-block">Estado Actual</label>
                <% if (device.status==='Asignado' ) { %>
                  <span class="badge bg-danger">Asignado</span>
                  <% } else { %>
                    <span class="badge bg-success">
                      <%= device.status %>
                    </span>
                    <% } %>
              </div>
              <div class="col-12">
                <hr class="opacity-10">
              </div>
              <div class="col-6">
                <label class="text-secondary small d-block">CPU</label>
                <span><i class="bi bi-processor me-2"></i>
                  <%= device.cpu || '-' %>
                </span>
              </div>
              <div class="col-6">
                <label class="text-secondary small d-block">RAM</label>
                <span><i class="bi bi-memory me-2"></i>
                  <%= device.ram || '-' %>
                </span>
              </div>
              <div class="col-6">
                <label class="text-secondary small d-block">Almacenamiento</label>
                <span><i class="bi bi-hdd-network me-2"></i>
                  <%= device.storage || '-' %>
                </span>
              </div>
              <div class="col-6">
                <label class="text-secondary small d-block">N° Serie</label>
                <span class="text-primary fw-medium">
                  <%= device.serial_number || '-' %>
                </span>
              </div>
              <div class="col-12">
                <hr class="opacity-10">
              </div>
              <div class="col-6">
                <label class="text-secondary small d-block">Ubicación</label>
                <span><i class="bi bi-geo-alt me-2"></i>
                  <%= device.location || '-' %>
                </span>
              </div>
              <div class="col-6">
                <label class="text-secondary small d-block">Responsable</label>
                <span><i class="bi bi-person me-2"></i>
                  <%= device.responsible || '-' %>
                </span>
              </div>
            </div>

            <div class="mt-4">
              <label class="text-secondary small d-block">Observaciones</label>
              <div class="p-3 rounded border mt-1 bg-light">
                <%= device.observations || 'Sin observaciones.' %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-7">
        <div class="card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-clock-history me-2"></i> Historial de Asignaciones</span>
            <% if (currentRole==='admin' || currentRole==='editor' ) { %>
              <button class="btn btn-primary btn-sm" type="button" data-bs-toggle="collapse"
                data-bs-target="#assignForm">
                <i class="bi bi-plus-lg"></i> Asignar
              </button>
              <% } %>
          </div>
          <div class="card-body">

            <% if (currentRole==='admin' || currentRole==='editor' ) { %>
              <div class="collapse mb-4" id="assignForm">
                <div class="p-3 bg-light rounded border border-primary shadow-sm">
                  <h6 class="text-primary mb-3">Nueva Asignación</h6>
                  <form method="POST" action="/devices/<%= device.id %>/assign">
                    <div class="row g-3">
                      <div class="col-md-6">
                        <label class="form-label small text-secondary">Asignado a</label>
                        <input class="form-control" name="assigned_to" required>
                      </div>
                      <div class="col-md-6">
                        <label class="form-label small text-secondary">Cargo</label>
                        <input class="form-control" name="role">
                      </div>
                      <div class="col-md-6">
                        <label class="form-label small text-secondary">Área</label>
                        <input class="form-control" name="area">
                      </div>
                      <div class="col-md-6">
                        <label class="form-label small text-secondary">Fecha entrega</label>
                        <input type="date" class="form-control" name="assigned_date" required>
                      </div>
                      <div class="col-12">
                        <label class="form-label small text-secondary">Notas</label>
                        <input class="form-control" name="notes">
                      </div>
                    </div>
                    <div class="mt-3 d-flex justify-content-end gap-2">
                      <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="collapse"
                        data-bs-target="#assignForm">Cancelar</button>
                      <button class="btn btn-primary btn-sm">Confirmar Asignación</button>
                    </div>
                  </form>
                </div>
              </div>
              <% } %>

                <div class="table-responsive">
                  <table class="table table-hover align-middle">
                    <thead>
                      <tr>
                        <th>Persona</th>
                        <th>Área</th>
                        <th>Entrega</th>
                        <th>Devolución</th>
                        <th class="text-end">Estado</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% if (assignments.length===0) { %>
                        <tr>
                          <td colspan="5" class="text-center p-4 text-secondary">Sin historial de asignaciones.</td>
                        </tr>
                        <% } %>

                          <% assignments.forEach(a=> { %>
                            <tr>
                              <td>
                                <div class="fw-bold">
                                  <%= a.assigned_to %>
                                </div>
                                <div class="small text-secondary">
                                  <%= a.role %>
                                </div>
                              </td>
                              <td>
                                <%= a.area || '-' %>
                              </td>
                              <td>
                                <%= a.assigned_date || '-' %>
                              </td>
                              <td>
                                <% if (!a.returned_date && (currentRole==='admin' || currentRole==='editor' )) { %>
                                  <form method="POST" action="/assignments/<%= a.id %>/close"
                                    class="d-flex gap-1 align-items-center">
                                    <input type="date" name="returned_date" class="form-control form-control-sm w-auto"
                                      required>
                                    <button class="btn btn-outline-success btn-sm"><i
                                        class="bi bi-check-lg"></i></button>
                                  </form>
                                  <% } else { %>
                                    <%= a.returned_date || '-' %>
                                      <% } %>
                              </td>
                              <td class="text-end">
                                <% if (a.returned_date) { %>
                                  <i class="bi bi-check-circle-fill text-success"></i>
                                  <% } else { %>
                                    <span class="badge text-bg-warning">Activa</span>
                                    <% } %>
                              </td>
                            </tr>
                            <% }) %>
                    </tbody>
                  </table>
                </div>
          </div>
        </div>
      </div>
    </div>

  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
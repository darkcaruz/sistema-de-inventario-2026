<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title><%= device ? 'Editar Equipo' : 'Nuevo Equipo' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
<nav class="navbar navbar-dark bg-dark mb-4">
  <div class="container-fluid">
    <a class="navbar-brand" href="/devices">Inventario</a>
    <a href="/logout" class="btn btn-outline-light btn-sm">Salir</a>
  </div>
</nav>

<div class="container">

  <h3 class="mb-4"><%= device ? 'Editar Equipo' : 'Nuevo Equipo' %></h3>

  <form method="POST" action="<%= device ? '/devices/' + device.id + '/edit' : '/devices/new' %>">

    <!-- Primera fila: código, nombre, marca/modelo -->
    <div class="row mb-3">
      <div class="col-md-4">
        <label class="form-label">Código interno</label>
        <input
          type="text"
          class="form-control"
          name="code"
          value="<%= device ? device.code || '' : '' %>">
      </div>

      <div class="col-md-4">
        <label class="form-label">Nombre equipo</label>
        <input
          type="text"
          class="form-control"
          name="name"
          required
          value="<%= device ? device.name || '' : '' %>">
      </div>

      <div class="col-md-4">
        <label class="form-label">Marca / Modelo</label>
        <input
          type="text"
          class="form-control"
          name="brand_model"
          value="<%= device ? device.brand_model || '' : '' %>">
      </div>
    </div>

    <!-- Segunda fila: CPU, RAM, Disco -->
    <div class="row mb-3">
      <div class="col-md-4">
        <label class="form-label">CPU</label>
        <input
          type="text"
          class="form-control"
          name="cpu"
          placeholder="Ej: Intel i5 10ª gen"
          value="<%= device ? device.cpu || '' : '' %>">
      </div>

      <div class="col-md-4">
        <label class="form-label">RAM</label>
        <input
          type="text"
          class="form-control"
          name="ram"
          placeholder="Ej: 16 GB"
          value="<%= device ? device.ram || '' : '' %>">
      </div>

      <div class="col-md-4">
        <label class="form-label">Disco</label>
        <input
          type="text"
          class="form-control"
          name="storage"
          placeholder="Ej: 512 GB SSD"
          value="<%= device ? device.storage || '' : '' %>">
      </div>
    </div>

    <!-- Tercera fila: Nº serie, ubicación, responsable -->
    <div class="row mb-3">
      <div class="col-md-4">
        <label class="form-label">N° Serie</label>
        <input
          type="text"
          class="form-control"
          name="serial_number"
          value="<%= device ? device.serial_number || '' : '' %>">
      </div>

      <div class="col-md-4">
        <label class="form-label">Ubicación</label>
        <input
          type="text"
          class="form-control"
          name="location"
          placeholder="Ej: Bellavista, Logística, etc."
          value="<%= device ? device.location || '' : '' %>">
      </div>

      <div class="col-md-4">
        <label class="form-label">Responsable / Asignado a</label>
        <input
          type="text"
          class="form-control"
          name="responsible"
          placeholder="Nombre de la persona que tiene el equipo"
          value="<%= device ? device.responsible || '' : '' %>">
      </div>
    </div>

    <!-- Observaciones -->
    <div class="mb-3">
      <label class="form-label">Observaciones</label>
      <textarea
        class="form-control"
        name="observations"
        rows="3"
        placeholder="Notas sobre el equipo, estado físico, accesorios, etc."><%= device ? (device.observations || '') : '' %></textarea>
    </div>

    <!-- Estado -->
    <div class="row mb-3">
      <div class="col-md-3">
        <label class="form-label">Estado</label>
        <select name="status" class="form-select">
          <option value="Disponible" <%= device && device.status === 'Disponible' ? 'selected' : '' %>>Disponible</option>
          <option value="Asignado" <%= device && device.status === 'Asignado' ? 'selected' : '' %>>Asignado</option>
          <option value="En mantención" <%= device && device.status === 'En mantención' ? 'selected' : '' %>>En mantención</option>
          <option value="Dado de baja" <%= device && device.status === 'Dado de baja' ? 'selected' : '' %>>Dado de baja</option>
          <option value="Perdido" <%= device && device.status === 'Perdido' ? 'selected' : '' %>>Perdido</option>
        </select>
      </div>
    </div>

    <button class="btn btn-primary" type="submit">Guardar</button>
    <a href="/devices" class="btn btn-secondary">Volver</a>

  </form>
</div>

</body>
</html>

<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login | INFORMATICA</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    .login-container {
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      background-color: var(--bg-body);
    }

    .login-card {
      width: 100%;
      max-width: 400px;
      padding: 2.5rem;
      border-radius: var(--radius);
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      box-shadow: var(--shadow-md);
    }

    .login-logo {
      font-size: 2.5rem;
      color: var(--primary-color);
      margin-bottom: 1.5rem;
      text-align: center;
    }

    .login-title {
      font-weight: 700;
      color: var(--text-main);
      text-align: center;
      margin-bottom: 2rem;
      font-size: 1.1rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }
  </style>
</head>

<body>

  <div class="login-container">
    <div class="login-card">
      <div class="login-logo">
        <i class="bi bi-shield-lock"></i>
      </div>

      <h2 class="login-title">Acceso al Sistema</h2>

      <% if (error) { %>
        <div class="alert alert-danger py-2 small border-0 bg-danger bg-opacity-10 text-danger text-center mb-4">
          <i class="bi bi-exclamation-triangle me-2"></i>
          <%= error %>
        </div>
        <% } %>

          <form method="POST" action="/login">
            <div class="mb-4">
              <label class="form-label small text-secondary">ID USUARIO</label>
              <div class="input-group">
                <span class="input-group-text bg-transparent border-end-0 border-secondary-subtle">
                  <i class="bi bi-person text-primary"></i>
                </span>
                <input type="text" name="username" class="form-control border-start-0 ps-0" required
                  placeholder="admin">
              </div>
            </div>

            <div class="mb-5">
              <label class="form-label small text-secondary">CONTRASEÑA</label>
              <div class="input-group">
                <span class="input-group-text bg-transparent border-end-0 border-secondary-subtle">
                  <i class="bi bi-key text-primary"></i>
                </span>
                <input type="password" name="password" class="form-control border-start-0 ps-0" required
                  placeholder="••••••••">
              </div>
            </div>

            <button class="btn btn-primary w-100 py-3 mb-4" type="submit">
              INICIAR SESIÓN <i class="bi bi-arrow-right-short ms-2"></i>
            </button>

            <div class="text-center">
              <span class="text-secondary smaller" style="font-size: 0.7rem;">INFORMATICA &copy; 2026 | INF-CORE
                v2.0</span>
            </div>
          </form>
    </div>
  </div>

</body>

</html>
<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inventario | INFORMATICA</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>

  <nav class="navbar navbar-expand-lg sticky-top">
    <div class="container-fluid">
      <a class="navbar-brand" href="/devices">
        <i class="bi bi-cpu-fill me-2"></i>INFORMATICA
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item">
            <a class="nav-link active" href="/devices">Equipos</a>
          </li>
          <% if (currentRole==='admin' ) { %>
            <li class="nav-item">
              <a class="nav-link text-secondary" href="/users">Usuarios</a>
            </li>
            <% } %>
        </ul>
        <div class="navbar-text me-3 d-none d-lg-block">
          <span class="badge text-bg-info">
            <i class="bi bi-person-fill me-1"></i>
            <%= currentUser %> — <%= currentRole %>
          </span>
        </div>
        <a href="/logout" class="btn btn-outline-secondary btn-sm"><i class="bi bi-box-arrow-right me-1"></i> Salir</a>
      </div>
    </div>
  </nav>

  <div class="container mt-5 animate-fade-in">

    <!-- Título y botones -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5">
      <div>
        <h2 class="mb-1">Equipos Registrados</h2>
        <p class="text-secondary small">Panel de gestión de inventario tecnológico</p>
      </div>

      <div class="d-flex gap-2 mt-3 mt-md-0">
        <% if (currentRole==='admin' || currentRole==='editor' ) { %>
          <a href="/devices/new" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i> Nuevo Equipo</a>
          <% } %>
            <a href="/devices/export/excel" class="btn btn-outline-primary btn-sm">📥 Exportar</a>
      </div>
    </div>

    <!-- Filtros avanzados -->
    <div class="card mb-5">
      <div class="card-header">
        <i class="bi bi-filter me-2"></i> Filtros de Búsqueda
      </div>
      <div class="card-body">
        <form method="GET" action="/devices" class="row g-3">
          <div class="col-md-3">
            <label class="form-label">Buscar</label>
            <input type="text" name="search" class="form-control" placeholder="Nombre, código..." value="<%= search %>">
          </div>

          <div class="col-md-2">
            <label class="form-label">Estado</label>
            <select name="status" class="form-select">
              <option value="">(Todos)</option>
              <option value="Disponible" <%=statusFilter==='Disponible' ? 'selected' : '' %>>Disponible</option>
              <option value="Asignado" <%=statusFilter==='Asignado' ? 'selected' : '' %>>Asignado</option>
              <option value="En mantención" <%=statusFilter==='En mantención' ? 'selected' : '' %>>En mantención
              </option>
              <option value="Dado de baja" <%=statusFilter==='Dado de baja' ? 'selected' : '' %>>Dado de baja</option>
            </select>
          </div>

          <div class="col-md-2">
            <label class="form-label">Ubicación</label>
            <input type="text" name="location" class="form-control" placeholder="Ej: Oficina"
              value="<%= locationFilter %>">
          </div>

          <div class="col-md-2">
            <label class="form-label">Marca</label>
            <input type="text" name="brand" class="form-control" placeholder="Ej: Dell" value="<%= brandFilter %>">
          </div>

          <div class="col-md-12 d-flex justify-content-end gap-2">
            <button class="btn btn-primary btn-sm" type="submit"><i class="bi bi-search me-1"></i> Filtrar</button>
            <a href="/devices" class="btn btn-outline-secondary btn-sm">Limpiar</a>
          </div>
        </form>
      </div>
    </div>

    <!-- Tabla -->
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead>
          <tr>
            <th>ID</th>
            <th>Código</th>
            <th>Nombre</th>
            <th>Marca/Modelo</th>
            <th>Estado</th>
            <th>Responsable</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% if (devices.length===0) { %>
            <tr>
              <td colspan="7" class="text-center p-5 text-secondary">
                <i class="bi bi-search mb-3 d-block" style="font-size: 2rem;"></i>
                No hay equipos que coincidan con los filtros.
              </td>
            </tr>
            <% } %>

              <% devices.forEach(d=> { %>
                <tr>
                  <td><span class="text-primary fw-medium">#<%= d.id %></span></td>
                  <td><strong>
                      <%= d.code || '-' %>
                    </strong></td>
                  <td>
                    <%= d.name || '-' %>
                  </td>
                  <td><span class="text-secondary">
                      <%= d.brand_model || '-' %>
                    </span></td>

                  <td>
                    <% if (d.status==='Asignado' ) { %>
                      <span class="badge bg-danger">Asignado</span>
                      <% } else if (d.status==='En mantención' ) { %>
                        <span class="badge bg-warning">En mantención</span>
                        <% } else if (d.status==='Dado de baja' ) { %>
                          <span class="badge bg-secondary">Baja</span>
                          <% } else { %>
                            <span class="badge bg-success">Disponible</span>
                            <% } %>
                  </td>

                  <td>
                    <%= d.responsible || '-' %>
                  </td>

                  <td class="text-end">
                    <a href="/devices/<%= d.id %>" class="btn btn-sm btn-outline-primary">
                      <i class="bi bi-eye"></i>
                    </a>
                  </td>
                </tr>
                <% }) %>
        </tbody>
      </table>
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Inventario de Equipos</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<nav class="navbar navbar-dark bg-dark mb-4">
  <div class="container-fluid">
    <a class="navbar-brand" href="/devices">Inventario</a>
    <div class="d-flex gap-3">
      <span class="navbar-text text-light">
        Usuario: <b><%= currentUser %></b> — Rol: <b><%= currentRole %></b>
      </span>
      <a href="/logout" class="btn btn-outline-light btn-sm">Salir</a>
    </div>
  </div>
</nav>

<div class="container">

  <!-- Título y botones -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Equipos Registrados</h3>

    <div class="d-flex gap-2">
      <% if (currentRole === 'admin' || currentRole === 'editor') { %>
        <a href="/devices/new" class="btn btn-primary btn-sm">+ Nuevo Equipo</a>
      <% } %>
      <a href="/devices/export/excel" class="btn btn-success btn-sm">📥 Exportar Excel</a>
    </div>
  </div>

  <!-- Filtros avanzados -->
  <form method="GET" action="/devices" class="row g-2 mb-4">

    <div class="col-md-4">
      <label class="form-label mb-1">Buscar texto</label>
      <input
        type="text"
        name="search"
        class="form-control"
        placeholder="Nombre, código, serie..."
        value="<%= search %>">
    </div>

    <div class="col-md-2">
      <label class="form-label mb-1">Estado</label>
      <select name="status" class="form-select">
        <option value="">(Todos)</option>
        <option value="Disponible" <%= statusFilter === 'Disponible' ? 'selected' : '' %>>Disponible</option>
        <option value="Asignado" <%= statusFilter === 'Asignado' ? 'selected' : '' %>>Asignado</option>
        <option value="En mantención" <%= statusFilter === 'En mantención' ? 'selected' : '' %>>En mantención</option>
        <option value="Dado de baja" <%= statusFilter === 'Dado de baja' ? 'selected' : '' %>>Dado de baja</option>
        <option value="Perdido" <%= statusFilter === 'Perdido' ? 'selected' : '' %>>Perdido</option>
      </select>
    </div>

    <div class="col-md-2">
      <label class="form-label mb-1">Ubicación</label>
      <input
        type="text"
        name="location"
        class="form-control"
        placeholder="Ej: Bellavista"
        value="<%= locationFilter %>">
    </div>

    <div class="col-md-2">
      <label class="form-label mb-1">Marca/Modelo</label>
      <input
        type="text"
        name="brand"
        class="form-control"
        placeholder="Ej: Dell, HP..."
        value="<%= brandFilter %>">
    </div>

    <div class="col-md-2">
      <label class="form-label mb-1">Responsable</label>
      <input
        type="text"
        name="responsible"
        class="form-control"
        placeholder="Nombre persona"
        value="<%= responsibleFilter %>">
    </div>

    <div class="col-12 d-flex justify-content-end mt-2">
      <button class="btn btn-dark btn-sm me-2" type="submit">🔍 Filtrar</button>
      <a href="/devices" class="btn btn-secondary btn-sm">Limpiar</a>
    </div>
  </form>

  <!-- Tabla -->
  <table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>ID</th>
        <th>Código</th>
        <th>Nombre</th>
        <th>Marca/Modelo</th>
        <th>N° Serie</th>       <!-- 🔥 NUEVA COLUMNA -->
        <th>Estado</th>
        <th>Responsable</th>
        <th>Ubicación</th>
        <th></th>
      </tr>
    </thead>

    <tbody>
      <% if (devices.length === 0) { %>
        <tr>
          <td colspan="9" class="text-center p-3">No hay equipos que coincidan con el filtro.</td>
        </tr>
      <% } %>

      <% devices.forEach(d => { %>
        <tr>
          <td><%= d.id %></td>
          <td><%= d.code || '-' %></td>
          <td><%= d.name || '-' %></td>
          <td><%= d.brand_model || '-' %></td>
          <td><%= d.serial_number || '-' %></td> <!-- 👈 SERIE -->
          
          <td>
            <% if (d.status === 'Asignado') { %>
              <span class="badge bg-danger">Asignado</span>
            <% } else if (d.status === 'En mantención') { %>
              <span class="badge bg-warning text-dark">En mantención</span>
            <% } else if (d.status === 'Dado de baja') { %>
              <span class="badge bg-secondary">Dado de baja</span>
            <% } else if (d.status === 'Perdido') { %>
              <span class="badge bg-dark">Perdido</span>
            <% } else { %>
              <span class="badge bg-success">Disponible</span>
            <% } %>
          </td>

          <td><%= d.responsible || '-' %></td>
          <td><%= d.location || '-' %></td>

          <td>
            <a href="/devices/<%= d.id %>" class="btn btn-sm btn-outline-dark">Ver</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

</div>
</body>
</html>
